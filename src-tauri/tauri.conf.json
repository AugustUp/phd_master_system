{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "博士工作台",
  "version": "0.1.0",
  "identifier": "com.codex.phd-workbench",
  "build": {
    "frontendDist": "../app",
    "beforeDevCommand": "npm run prepare:static",
    "beforeBuildCommand": "npm run prepare:static"
  },
  "app": {
    "windows": [
      {
        "title": "博士工作台",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
