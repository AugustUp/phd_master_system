{
  "name": "phd-workbench-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "博士工作台 Tauri v2 desktop wrapper",
  "scripts": {
    "prepare:static": "node ./scripts/prepare-static.mjs && npm run build:css && node ./scripts/copy-vendor.mjs",
    "build": "npm run prepare:static",
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./app/assets/tailwind.input.css -o ./app/assets/tailwind.css --minify",
    "cap:sync:android": "npm run prepare:static && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "android:debug": "cd android && gradlew.bat assembleDebug",
    "tauri:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-dev.ps1",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build.ps1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "chart.js": "^4.4.8"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@tauri-apps/cli": "^2.0.0",
    "tailwindcss": "^3.4.17"
  }
}
